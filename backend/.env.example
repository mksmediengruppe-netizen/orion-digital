# ORION Digital — Environment Variables
# Copy to .env and fill in values

# ═══ Required ═══
OPENROUTER_API_KEY=your_openrouter_key
ORION_ENCRYPT_KEY=generate_with_python3_-c_from_cryptography.fernet_import_Fernet;_print(Fernet.generate_key().decode())

# ═══ Optional ═══
SSH_HOST_POLICY=bootstrap          # bootstrap (default) or strict
PLAYWRIGHT_MAX_WORKERS=2           # browser thread pool size
PORT=3510                          # API port

